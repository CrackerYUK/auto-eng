# Django core settings
DJANGO_SECRET_KEY=change-me-use-a-long-random-secret
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,permit-system.example.org

# Database
# Leave DATABASE_URL unset or commented for offline local SQLite (db.sqlite3).
# Set DATABASE_URL for PostgreSQL in Docker/test deployment.
DATABASE_URL=postgresql://permit_system:permit_system@db:5432/permit_system

# PostgreSQL container defaults used by docker-compose.yml.
POSTGRES_DB=permit_system
POSTGRES_USER=permit_system
POSTGRES_PASSWORD=permit_system

# Static and media files inside the container/server
STATIC_ROOT=/app/staticfiles
MEDIA_ROOT=/app/media

# Optional PDF conversion
PDF_CONVERTER_ENABLED=0
SOFFICE_PATH=soffice
